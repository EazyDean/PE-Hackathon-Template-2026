FLASK_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=5000
APP_INSTANCE_NAME=local-app
LOG_LEVEL=INFO
DATABASE_NAME=hackathon_db
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
